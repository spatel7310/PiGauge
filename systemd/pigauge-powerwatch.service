 [Unit]
 Description=PiGauge power-loss safe shutdown watcher
 
 [Service]
 Type=simple
 Environment=RUST_LOG=info
 ExecStart=/home/spatel7310/PiGauge/target/release/pigauge power-watch --gpio-line 6 --debounce-ms 15000 --shutdown-delay-ms 500
 Restart=always
 RestartSec=2
 
 # Needs GPIO + shutdown permissions; simplest is root.
 User=root
 
 [Install]
 WantedBy=multi-user.target
 
